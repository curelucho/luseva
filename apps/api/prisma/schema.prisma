generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  AGENT
}

enum ChannelType {
  WHATSAPP
  TELEGRAM
  EMAIL
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  ARCHIVED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageSender {
  CONTACT
  USER
  AI
  SYSTEM
}

enum AppointmentStatus {
  SCHEDULED
  RESCHEDULED
  CANCELLED
  COMPLETED
}

enum AutomationTrigger {
  APPOINTMENT_CREATED
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELLED
  CONVERSATION_IDLE
}

model Workspace {
  id            String         @id @default(cuid())
  name          String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  users         User[]
  contacts      Contact[]
  channels      Channel[]
  conversations Conversation[]
  appointments  Appointment[]
  automations   Automation[]
}

model User {
  id           String    @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(AGENT)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignedConversations Conversation[] @relation("ConversationAssignee")
}

model Contact {
  id            String         @id @default(cuid())
  workspaceId   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  email         String?
  phone         String?
  externalId    String?
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  appointments  Appointment[]

  @@index([workspaceId])
}

model Channel {
  id            String         @id @default(cuid())
  workspaceId   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type          ChannelType
  name          String
  isActive      Boolean        @default(false)
  credentials   Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]

  @@unique([workspaceId, type])
}

model Conversation {
  id             String             @id @default(cuid())
  workspaceId    String
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channelId      String
  channel        Channel            @relation(fields: [channelId], references: [id], onDelete: Restrict)
  assigneeId     String?
  assignee       User?              @relation("ConversationAssignee", fields: [assigneeId], references: [id])
  status         ConversationStatus @default(OPEN)
  tags           String[]           @default([])
  detectedIntent String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  messages       Message[]

  @@index([workspaceId, status])
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      MessageDirection
  sender         MessageSender
  body           String
  metadata       Json?
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

model Appointment {
  id             String            @id @default(cuid())
  workspaceId    String
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactId      String
  contact        Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  service        String
  professional   String?
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([workspaceId, startsAt])
}

model Automation {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  trigger     AutomationTrigger
  isActive    Boolean           @default(true)
  config      Json
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([workspaceId, trigger])
}
