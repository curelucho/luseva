{
  "name": "luseva-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Luseva AI - Plataforma omnicanal de atencion y gestion de turnos con IA.",
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "db:generate": "npm run prisma:generate -w @luseva/api",
    "db:migrate": "npm run prisma:migrate -w @luseva/api"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "postcss": "^8.5.15"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  }
}
